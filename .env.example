# Google Gemini API Key (required)
GOOGLE_API_KEY=your-api-key-here

# Model configuration (optional — sensible defaults provided)
DREAMER_MODEL=gemini-2.0-pro-exp
JUDGE_MODEL=gemini-1.5-pro
EXECUTOR_MODEL=gemini-2.0-flash

# Temporal configuration (optional — needed for durable execution)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Dream schedule (optional — defaults to every 6 hours)
DREAM_INTERVAL_HOURS=6

# Consolidation schedule (optional — defaults to 03:00 UTC)
CONSOLIDATION_HOUR_UTC=3

# Embedding backend for episodic memory (optional — Phase 2)
# Options: ollama (default, uses nomic-embed-text), gemini
EMBEDDING_BACKEND=ollama
